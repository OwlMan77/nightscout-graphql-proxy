{
  "name": "nightscout-graphql-proxy",
  "version": "1.0.0",
  "description": "GraphQL proxy for Nightscout API",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "package": "node build.mjs",
    "deploy": "node deploy.mjs",
    "key": "terraform -chdir=infra output -raw proxy_api_key"
  },
  "keywords": [
    "nightscout",
    "graphql",
    "proxy"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "graphql": "^16.8.1",
    "graphql-yoga": "^5.3.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20.19.43",
    "adm-zip": "^0.6.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
