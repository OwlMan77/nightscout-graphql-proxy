# Base URL of your Nightscout API instance
NIGHTSCOUT_URL=https://your-nightscout-url.com/api/v1

# Nightscout API secret (SHA1-hashed value your instance expects)
NIGHTSCOUT_API_SECRET=your_hashed_api_secret

# Static key clients must send as the `x-api-key` header to reach this proxy.
# Used by the Lambda handler; leave unset locally to disable the check.
PROXY_API_KEY=generate-a-long-random-string

# Local dev server port (ignored on Lambda)
PORT=4000
